"VertexLitGeneric"
{
	$basetexture			"models/premuda/tarp_blu"

	$phong					"1"
	$phongboost				"30"
	$phongfresnelranges		"[.035 1 1]"
	$phongalbedotint		"1"
	
	$basealphaenvmapmask 1

	$envmap					"env_cubemap"
	$envmaptint				"[1 1 1]"
	$envmapfresnel			"1.0"

	$rimlight				"1"
	$rimmask				"1"

	$halflambert				"0"
	$phongdisablehalflambert	"1"

	$ambientocclusion		".5"
	
	%keywords "tf"
}