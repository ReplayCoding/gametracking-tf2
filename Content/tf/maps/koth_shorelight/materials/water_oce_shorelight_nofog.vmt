"Water"
{
	<dx90
	{
		 	"$fallbackmaterial" "water_ocean_shorelight_cheap"
	}
	"%keywords" "tf"
	"%tooltexture" "water_ocean_shorelight_normal"
	"%compilewater" 1
	"$abovewater" 1
	"$envmap" "env_cubemap"	
	"$refracttexture" "_rt_WaterRefraction"

	"$refractamount" "0.5"
	"$refracttint" "{145 224 255}"
	"$refractblur" "0"

//	"$reflecttexture" "env_cubemap"
	"$reflectamount" "0.1"
	"$reflecttint" "{255 255 255}"

	"$scale" "[2 2]"
	"$normalmap" "water_ocean_shorelight_normal"
	"$surfaceprop" "water"
	"$bottommaterial" "water_ocean_shorelight_beneath"
	"$bumpframe" "0"

	"$fogenable" 1
	"$fogcolor" "{48 120 154}" Old Colour
//	"$fogcolor" "{47 135 153}"
	"$fogstart" "0"
	"$fogend" "400"

	"$nofog" "1"

	"Proxies"
	{
		"AnimatedTexture"
		{
			"animatedtexturevar" "$normalmap"
			"animatedtextureframenumvar" "$bumpframe"
			"animatedtextureframerate" 30.00
		}
		"WaterLOD"
		{
			// fixme!  This has to be here, or material loading barfs.
			"dummy" 0
		}
	}

}
