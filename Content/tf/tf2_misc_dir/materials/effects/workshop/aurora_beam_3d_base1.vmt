"UnlitGeneric"
{
	"$basetexture" "effects/workshop/aurora_beam_3d_base1"
	"$detail" "effects/workshop/aurora_grad_color"
	"$detailscale" "1"
	"$detailblendfactor" 1
	"$detailblendmode" "2"

	"$translucent" 1
	"$additive" 1
	"$vertexcolor" 	1
	"$vertexalpha"	1
	"$depthblend" 	0
//                "$overbrightfactor"  5
	$nocull 1
//	"$spriterendermode" 4
	"Proxies"
	{
		"TextureScroll"
		{
			"texturescrollvar" "$basetexturetransform"
			"texturescrollrate" .025
			"texturescrollangle" 0
		}
		"TextureScroll"
		{
			"texturescrollvar" "$detailtexturetransform"
			"texturescrollrate" "-.012"
			"texturescrollangle" 0
		}
	}
}